{
  "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
  "metadata": {
    "owner": "platform-team@example.com",
    "version": "1.0.0",
    "created": "2026-03-07",
    "description": "E-commerce order processing platform",
    "tags": ["ecommerce", "microservices", "orders"],
    "repository": "https://github.com/ArchRails/archrails-ecommerce-java",
    "notes": "ArchRails demo — archrails-ecommerce-java"
  },
  "nodes": [
    {
      "unique-id": "actor-customer",
      "node-type": "actor",
      "name": "Customer",
      "description": "End user who browses catalog and places orders",
      "metadata": { "owner": "product-team@example.com", "contact": "support@example.com" }
    },
    {
      "unique-id": "actor-admin",
      "node-type": "actor",
      "name": "Admin",
      "description": "Administrative user who manages orders and inventory",
      "metadata": { "owner": "ops-team@example.com", "contact": "ops@example.com" }
    },
    {
      "unique-id": "service-api-gateway",
      "node-type": "service",
      "name": "API Gateway",
      "description": "Public HTTP API surface; routes requests to internal services, enforces auth and rate limits",
      "interfaces": [
        { "unique-id": "iface-api-http", "protocol": "HTTPS", "host": "api.example.com", "port": 443 }
      ],
      "metadata": {
        "owner": "platform-team@example.com",
        "repository": "https://github.com/ArchRails/archrails-ecommerce-java",
        "deployment-type": "kubernetes",
        "runtime": "nodejs:18",
        "replicas": 3
      }
    },
    {
      "unique-id": "service-order",
      "node-type": "service",
      "name": "Order Service",
      "description": "Handles order placement, validation, lifecycle and events",
      "interfaces": [
        { "unique-id": "iface-order-rest", "protocol": "HTTPS", "host": "order-service", "port": 8080 }
      ],
      "metadata": { "owner": "orders-team@example.com", "deployment-type": "kubernetes", "runtime": "go:1.20" }
    },
    {
      "unique-id": "service-inventory",
      "node-type": "service",
      "name": "Inventory Service",
      "description": "Manages product stock levels, reservations and availability",
      "interfaces": [
        { "unique-id": "iface-inventory-rest", "protocol": "HTTPS", "host": "inventory-service", "port": 8080 }
      ],
      "metadata": { "owner": "catalog-team@example.com", "deployment-type": "kubernetes", "runtime": "python:3.11" }
    },
    {
      "unique-id": "service-payment",
      "node-type": "service",
      "name": "Payment Service",
      "description": "Processes payments, integrates with external payment providers",
      "interfaces": [
        { "unique-id": "iface-payment-rest", "protocol": "HTTPS", "host": "payment-service", "port": 8080 }
      ],
      "metadata": { "owner": "payments-team@example.com", "deployment-type": "kubernetes", "runtime": "java:17" }
    },
    {
      "unique-id": "external-payment-gateway",
      "node-type": "service",
      "name": "Payment Gateway",
      "description": "Third-party payment provider; processes card charges on behalf of Payment Service",
      "interfaces": [
        { "unique-id": "iface-ext-payment-https", "protocol": "HTTPS", "host": "payments.example-gateway.com", "port": 443 }
      ],
      "metadata": { "owner": "third-party", "contact": "support@example-gateway.com" }
    },
    {
      "unique-id": "db-orders",
      "node-type": "database",
      "name": "Order Database",
      "description": "Primary data store for orders and order history",
      "interfaces": [
        { "unique-id": "iface-orders-sql", "protocol": "JDBC", "host": "orders-db", "port": 5432 }
      ],
      "metadata": { "owner": "dba-team@example.com", "deployment-type": "managed-rds", "engine": "postgres", "version": "15" }
    },
    {
      "unique-id": "db-inventory",
      "node-type": "database",
      "name": "Inventory Database",
      "description": "Stores product stock levels and reservations",
      "interfaces": [
        { "unique-id": "iface-inventory-sql", "protocol": "JDBC", "host": "inventory-db", "port": 5432 }
      ],
      "metadata": { "owner": "dba-team@example.com", "deployment-type": "managed-rds", "engine": "postgres", "version": "15" }
    },
    {
      "unique-id": "system-ecommerce-platform",
      "node-type": "system",
      "name": "E-Commerce Platform",
      "description": "Top-level system containing the platform services and databases",
      "metadata": {
        "owner": "platform-team@example.com",
        "repository": "https://github.com/ArchRails/archrails-ecommerce-java",
        "deployment-type": "kubernetes",
        "region": "us-west-2"
      }
    }
  ],
  "relationships": [
    {
      "unique-id": "rel-interacts-customer-api",
      "description": "Customer interacts with API Gateway (public REST)",
      "relationship-type": {
        "interacts": {
          "actor": "actor-customer",
          "nodes": ["service-api-gateway"]
        }
      },
      "metadata": { "sla": "99.9%", "monitoring": "api-logs" }
    },
    {
      "unique-id": "rel-interacts-admin-api",
      "description": "Admin interacts with API Gateway (admin REST)",
      "relationship-type": {
        "interacts": {
          "actor": "actor-admin",
          "nodes": ["service-api-gateway"]
        }
      },
      "metadata": { "sla": "99.9%", "monitoring": "api-logs" }
    },
    {
      "unique-id": "rel-connects-api-order",
      "description": "API Gateway routes order requests to Order Service",
      "relationship-type": {
        "connects": {
          "source": { "node": "service-api-gateway", "interfaces": ["iface-api-http"] },
          "destination": { "node": "service-order", "interfaces": ["iface-order-rest"] }
        }
      },
      "metadata": { "sla": "99.95%", "monitoring": "gateway->order:traces", "protocol": "REST" }
    },
    {
      "unique-id": "rel-connects-api-inventory",
      "description": "API Gateway routes inventory requests to Inventory Service",
      "relationship-type": {
        "connects": {
          "source": { "node": "service-api-gateway", "interfaces": ["iface-api-http"] },
          "destination": { "node": "service-inventory", "interfaces": ["iface-inventory-rest"] }
        }
      },
      "metadata": { "sla": "99.95%", "monitoring": "gateway->inventory:traces", "protocol": "REST" }
    },
    {
      "unique-id": "rel-connects-order-inventory",
      "description": "Order Service calls Inventory Service to check and reserve stock",
      "relationship-type": {
        "connects": {
          "source": { "node": "service-order", "interfaces": ["iface-order-rest"] },
          "destination": { "node": "service-inventory", "interfaces": ["iface-inventory-rest"] }
        }
      },
      "metadata": { "sla": "99.9%", "monitoring": "order->inventory:traces" }
    },
    {
      "unique-id": "rel-connects-order-payment",
      "description": "Order Service calls Payment Service to process charges",
      "relationship-type": {
        "connects": {
          "source": { "node": "service-order", "interfaces": ["iface-order-rest"] },
          "destination": { "node": "service-payment", "interfaces": ["iface-payment-rest"] }
        }
      },
      "metadata": { "sla": "99.9%", "monitoring": "payment-traces", "retry-policy": "exponential-backoff" }
    },
    {
      "unique-id": "rel-connects-order-db",
      "description": "Order Service persists orders to Order Database",
      "relationship-type": {
        "connects": {
          "source": { "node": "service-order", "interfaces": ["iface-order-rest"] },
          "destination": { "node": "db-orders", "interfaces": ["iface-orders-sql"] }
        }
      },
      "metadata": { "sla": "99.99%", "backup": "daily", "monitoring": "db-metrics" }
    },
    {
      "unique-id": "rel-connects-inventory-db",
      "description": "Inventory Service reads and writes stock levels to Inventory Database",
      "relationship-type": {
        "connects": {
          "source": { "node": "service-inventory", "interfaces": ["iface-inventory-rest"] },
          "destination": { "node": "db-inventory", "interfaces": ["iface-inventory-sql"] }
        }
      },
      "metadata": { "sla": "99.99%", "backup": "daily", "monitoring": "db-metrics" }
    },
    {
      "unique-id": "rel-connects-payment-gateway",
      "description": "Payment Service calls external Payment Gateway to process card charges",
      "relationship-type": {
        "connects": {
          "source": { "node": "service-payment", "interfaces": ["iface-payment-rest"] },
          "destination": { "node": "external-payment-gateway", "interfaces": ["iface-ext-payment-https"] }
        }
      },
      "metadata": { "sla": "99.5%", "monitoring": "payment-gateway:traces" }
    },
    {
      "unique-id": "rel-composedof-ecommerce-platform",
      "description": "E-Commerce Platform is composed of all services and databases",
      "relationship-type": {
        "composed-of": {
          "container": "system-ecommerce-platform",
          "nodes": [
            "service-api-gateway",
            "service-order",
            "service-inventory",
            "service-payment",
            "db-orders",
            "db-inventory"
          ]
        }
      },
      "metadata": { "owner": "platform-team@example.com" }
    }
  ]
}